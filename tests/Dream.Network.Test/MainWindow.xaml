<Window x:Class="Dream.Network.Test.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Dream.Network.Test"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <DockPanel Background="#333333" LastChildFill="True">
        <DockPanel DockPanel.Dock="Bottom" LastChildFill="True" Height="30">
            <Button DockPanel.Dock="Right" Content="Send" Margin="5" Click="Button_Click"/>
            <TextBox x:Name="textBox" Margin="5"/>
        </DockPanel>
        <TextBlock x:Name="textMessages"/>
    </DockPanel>
</Window>
