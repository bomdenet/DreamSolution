<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Dream.Wpf.Notifications">
    <Style TargetType="{x:Type local:NotificationHost}">
        <Setter Property="Padding" Value="2"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:NotificationHost}">
                    <ItemsControl ItemsSource="{Binding Source={x:Static local:NotificationService.Notifications}}" Padding="{Binding Path=Padding, RelativeSource={RelativeSource TemplatedParent}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel HorizontalAlignment="{Binding Path=HorizontalAlignment, RelativeSource={RelativeSource TemplatedParent}}"
                                            VerticalAlignment="{Binding Path=VerticalAlignment, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ContentPresenter Content="{Binding Model}" Width="300" Margin="2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <DataTemplate DataType="{x:Type local:Notification}">
        <Border Background="LightBlue" Padding="10">
            <TextBlock Text="{Binding Message}" />
        </Border>
    </DataTemplate>

    <DataTemplate DataType="{x:Type local:NotificationSystemError}">
        <Border Background="Red" Padding="10">
            <StackPanel>
                <TextBlock Text="{Binding Message}" />
                <Button Content="Подробнее" />
            </StackPanel>
        </Border>
    </DataTemplate>
</ResourceDictionary>
